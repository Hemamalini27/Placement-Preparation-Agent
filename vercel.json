{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/main.py" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ],
  "functions": {
    "backend/main.py": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "env": {
    "GEMINI_API_KEY": "@gemini_api_key",
    "MONGO_URI": "@mongo_uri",
    "SECRET_KEY": "@jwt_secret"
  },
  "build": {
    "env": {
      "PYTHONUNBUFFERED": "1"
    }
  }
}
